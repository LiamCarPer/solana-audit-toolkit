{
  "version": "0.1.0",
  "name": "staking",
  "instructions": [
    {
      "name": "initializePool",
      "accounts": [
        {"name": "poolState", "isMut": true, "isSigner": false, "pda": {"seeds": [{"kind": "const", "value": [112, 111, 111, 108]}]}},
        {"name": "admin", "isMut": false, "isSigner": true},
        {"name": "systemProgram", "isMut": false, "isSigner": false}
      ],
      "args": [{"name": "rewardRate", "type": "u64"}]
    },
    {
      "name": "stake",
      "accounts": [
        {"name": "poolState", "isMut": true, "isSigner": false},
        {"name": "userStake", "isMut": true, "isSigner": false, "pda": {"seeds": [{"kind": "const", "value": [115, 116, 97, 107, 101]}, {"kind": "account", "path": "user"}]}},
        {"name": "user", "isMut": false, "isSigner": true},
        {"name": "tokenProgram", "isMut": false, "isSigner": false}
      ],
      "args": [{"name": "amount", "type": "u64"}]
    },
    {
      "name": "unstake",
      "accounts": [
        {"name": "poolState", "isMut": true, "isSigner": false},
        {"name": "userStake", "isMut": true, "isSigner": false, "pda": {"seeds": [{"kind": "const", "value": [115, 116, 97, 107, 101]}, {"kind": "account", "path": "user"}]}},
        {"name": "user", "isMut": false, "isSigner": true},
        {"name": "tokenProgram", "isMut": false, "isSigner": false}
      ],
      "args": [{"name": "amount", "type": "u64"}]
    },
    {
      "name": "claimRewards",
      "accounts": [
        {"name": "poolState", "isMut": true, "isSigner": false},
        {"name": "userStake", "isMut": true, "isSigner": false},
        {"name": "user", "isMut": false, "isSigner": true}
      ],
      "args": []
    },
    {
      "name": "closePool",
      "accounts": [
        {"name": "poolState", "isMut": true, "isSigner": false},
        {"name": "admin", "isMut": false, "isSigner": true}
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "PoolState",
      "type": {
        "kind": "struct",
        "fields": [
          {"name": "bump", "type": "u8"},
          {"name": "admin", "type": "publicKey"},
          {"name": "totalStaked", "type": "u64"},
          {"name": "rewardRate", "type": "u64"},
          {"name": "status", "type": {"defined": "PoolStatus"}},
          {"name": "isInitialized", "type": "bool"}
        ]
      }
    },
    {
      "name": "UserStake",
      "type": {
        "kind": "struct",
        "fields": [
          {"name": "bump", "type": "u8"},
          {"name": "owner", "type": "publicKey"},
          {"name": "amount", "type": "u64"},
          {"name": "rewardDebt", "type": "u64"}
        ]
      }
    }
  ],
  "types": [
    {
      "name": "PoolStatus",
      "type": {
        "kind": "enum",
        "variants": [
          {"name": "Active"},
          {"name": "Paused"},
          {"name": "Closed"}
        ]
      }
    }
  ]
}
